# =============================================================================
# BuLLQR — Default Environment Variables
# =============================================================================
# Safe defaults for Docker Compose. For production (Coolify/EC2),
# override these in Coolify's Environment Variables UI.

# --- PostgreSQL ---
POSTGRES_DB=cats_db
POSTGRES_USER=cats_user
POSTGRES_PASSWORD=cats_password
POSTGRES_PORT=5432

# --- Backend (FastAPI) ---
SECRET_KEY=change-this-in-production-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8
CORS_ORIGINS=*
TIMEZONE=Asia/Kolkata
BACKEND_PORT=8000

# --- System Administrator ---
SA_PASSWORD=admin123

# --- AI (optional, set your key in Coolify) ---
ANTHROPIC_API_KEY=

# --- Frontend ---
FRONTEND_PORT=80
